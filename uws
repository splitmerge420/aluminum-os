#!/usr/bin/env python3
"""
uws — Aluminum OS Universal Workspace Shell

Usage:
  uws status
  uws lint [<path>...]
  uws swarm review [--batch=N] [<item>...]
  uws audit [--last=N]
  uws workspace detect
  uws ai detect [--providers=ID,ID,...]
  uws ai ask [--provider=ID] [--timeout=N] <prompt>
"""

import argparse
import json
import os
import sys

# Resolve repo root so this script works regardless of where it is invoked.
_ROOT = os.path.dirname(os.path.abspath(__file__))
if _ROOT not in sys.path:
    sys.path.insert(0, _ROOT)

from python.core.uws_cli import (
    SwarmReviewItem,
    ai_ask,
    ai_detect,
    audit_summary,
    lint,
    status,
    swarm_review,
    workspace_detect,
)
from kintsugi.sdk.golden_trace import GoldenTraceEmitter


def _make_emitter() -> GoldenTraceEmitter:
    return GoldenTraceEmitter(repo="aluminum-os", module="uws/cli")


def cmd_status(_args) -> int:
    result = status()
    print(json.dumps(result.to_dict(), indent=2))
    return 0


def cmd_lint(args) -> int:
    paths = args.paths if args.paths else ["."]
    em = _make_emitter()
    result = lint(paths, emitter=em)
    print(json.dumps(result.to_dict(), indent=2))
    return 1 if result.violations > 0 else 0


def cmd_swarm_review(args) -> int:
    items = [
        SwarmReviewItem(id=str(i + 1), description=desc)
        for i, desc in enumerate(args.items or ["sample-item"])
    ]
    batch_size = args.batch or 50
    em = _make_emitter()
    result = swarm_review(items, batch_size=batch_size, emitter=em)
    print(json.dumps(result.to_dict(), indent=2))
    return 0 if result.npfm_score >= 0.7 else 1


def cmd_audit(args) -> int:
    em = _make_emitter()
    em.emit(
        event_type="query",
        sphere_tag="H0.S0",
        aluminum_layer="L3-Engine",
        payload={"query": "audit_summary"},
    )
    result = audit_summary(em, last_n=args.last)
    print(json.dumps(result.to_dict(), indent=2))
    return 0


def cmd_ai_detect(args) -> int:
    em = _make_emitter()
    ids = [s.strip() for s in args.providers.split(",")] if getattr(args, "providers", None) else None
    result = ai_detect(provider_ids=ids, emitter=em)
    print(json.dumps(result, indent=2))
    return 0 if result.get("available_ids") else 1


def cmd_ai_ask(args) -> int:
    em = _make_emitter()
    result = ai_ask(
        prompt=" ".join(args.prompt),
        provider_id=getattr(args, "provider", None),
        timeout=getattr(args, "timeout", 60),
        emitter=em,
    )
    print(json.dumps(result, indent=2))
    return 0 if result.get("success") else 1



    em = _make_emitter()
    result = workspace_detect(emitter=em)
    print(json.dumps(result, indent=2))
    return 0 if result.get("any_available") else 1


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="uws",
        description="Aluminum OS Universal Workspace Shell",
    )
    sub = parser.add_subparsers(dest="command")

    # status
    sub.add_parser("status", help="Show per-ring operational status")

    # lint
    lint_p = sub.add_parser("lint", help="Constitutional code linter")
    lint_p.add_argument("paths", nargs="*", help="Files or directories to lint")

    # swarm
    swarm_p = sub.add_parser("swarm", help="Swarm operations")
    swarm_sub = swarm_p.add_subparsers(dest="swarm_cmd")
    review_p = swarm_sub.add_parser("review", help="NPFM batch review gate")
    review_p.add_argument("--batch", type=int, default=50,
                          help="Max items per batch (default: 50)")
    review_p.add_argument("items", nargs="*", help="Items to review")

    # audit
    audit_p = sub.add_parser("audit", help="Kintsugi audit trace summary")
    audit_p.add_argument("--last", type=int, default=20,
                         help="Number of recent traces to summarise (default: 20)")

    # workspace
    ws_p = sub.add_parser("workspace", help="Google Workspace CLI integration")
    ws_sub = ws_p.add_subparsers(dest="ws_cmd")
    ws_sub.add_parser(
        "detect",
        help="Detect installed GWS tools (gws ≥0.18.1, gam ≥7.36.03, gyb ≥1.95)",
    )

    # ai
    ai_p = sub.add_parser("ai", help="Universal AI CLI provider registry")
    ai_sub = ai_p.add_subparsers(dest="ai_cmd")
    ai_detect_p = ai_sub.add_parser(
        "detect",
        help="Detect installed AI CLIs and show constitutional status",
    )
    ai_detect_p.add_argument(
        "--providers", default=None,
        help="Comma-separated provider IDs to check (default: all)",
    )
    ai_ask_p = ai_sub.add_parser(
        "ask",
        help="Route a prompt through the constitutional gate to an AI provider",
    )
    ai_ask_p.add_argument(
        "--provider", default=None,
        help="Provider ID (copilot, claude, gemini, deepseek, ollama, openai, gh)",
    )
    ai_ask_p.add_argument(
        "--timeout", type=int, default=60,
        help="Subprocess timeout in seconds (default: 60)",
    )
    ai_ask_p.add_argument("prompt", nargs="+", help="Prompt text")

    args = parser.parse_args()

    if args.command == "status":
        return cmd_status(args)
    if args.command == "lint":
        return cmd_lint(args)
    if args.command == "swarm":
        if getattr(args, "swarm_cmd", None) == "review":
            return cmd_swarm_review(args)
        swarm_p.print_help()
        return 1
    if args.command == "audit":
        return cmd_audit(args)
    if args.command == "workspace":
        if getattr(args, "ws_cmd", None) == "detect":
            return cmd_workspace_detect(args)
        ws_p.print_help()
        return 1
    if args.command == "ai":
        if getattr(args, "ai_cmd", None) == "detect":
            return cmd_ai_detect(args)
        if getattr(args, "ai_cmd", None) == "ask":
            return cmd_ai_ask(args)
        ai_p.print_help()
        return 1

    parser.print_help()
    return 1


if __name__ == "__main__":
    sys.exit(main())
